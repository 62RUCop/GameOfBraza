# ─────────────────────────────────────────────────────────────────────────────
# Production / Docker — пример переменных окружения.
# Скопируй в .env (его читает docker-compose). start.sh делает это автоматически
# и генерирует секреты при первом запуске.
#   cp .env.production.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL (внутри сети compose) ───────────────────────────────────────────
POSTGRES_USER=gob_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=gameofbraza

# DATABASE_URL собирается автоматически из POSTGRES_* (хост = db внутри compose).
# Задай вручную, только если используешь внешнюю БД:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Auth.js / NextAuth v5 ──────────────────────────────────────────────────────
# Оставь пустым — start.sh сгенерирует при первом запуске.
# Вручную: openssl rand -hex 32
AUTH_SECRET=
# Публичный URL приложения (для ссылок и редиректов auth).
# ОСТАВЬ ПУСТЫМ для доступа по IP/домену: origin берётся из Host-заголовка запроса
# (включён AUTH_TRUST_HOST в docker-compose). Жёсткий localhost тут перебрасывает
# вход на localhost — приложение работает только на самой машине-сервере.
# Задавай вручную ТОЛЬКО за обратным прокси, меняющим домен/протокол:
#   AUTH_URL=https://example.com
AUTH_URL=
NEXT_PUBLIC_APP_URL=

# ─── Первичный admin-аккаунт ────────────────────────────────────────────────────
# Создаётся идемпотентным сидом. Оставь ADMIN_PASSWORD пустым — start.sh
# сгенерирует пароль и напечатает его в конце запуска.
ADMIN_EMAIL=admin@gameofbraza.local
ADMIN_PASSWORD=

# ─── Порт веб-сервера на хосте ──────────────────────────────────────────────────
WEB_PORT=3000

# ─── Демо-данные ────────────────────────────────────────────────────────────────
# true → сид дополнительно создаёт dev-пользователей для быстрой проверки UI
# (тестовый персонаж будет добавлен позже). Для прод-окружения держи false.
SEED_DEMO=false
