{
  "extends": "@gob/config/tsconfig/nextjs",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "composite": false,
    // WebWorker нужен для типов service worker в src/app/sw.ts (ServiceWorkerGlobalScope).
    // Конфликты глобалей DOM/WebWorker гасит skipLibCheck из базового пресета.
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "allowJs": true,
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
