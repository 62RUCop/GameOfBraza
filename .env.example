# PostgreSQL (Docker dev)
DATABASE_URL="postgresql://gob_user:gob_password@localhost:5432/gameofbraza"

# Auth.js — скопируй этот файл в apps/web/.env.local и заполни
# Сгенерировать секрет: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="сгенерируй-случайный-hex-32-байта"
AUTH_URL="http://localhost:3000"

# S3-совместимое хранилище (Cloudflare R2 или любой S3)
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Telegram-бот (apps/bot) — токен от @BotFather. НЕ коммить реальный токен.
# Локально клади его в apps/bot/.env (файл в .gitignore).
BOT_TOKEN=""
# Порт HTTP-healthcheck бота (long-polling своего порта не открывает).
BOT_HEALTHCHECK_PORT="3001"
# Имя бота (без @) — для кликабельного deep-link в /settings. Необязательно.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=""
