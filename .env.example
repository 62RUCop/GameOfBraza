# PostgreSQL (Docker dev)
DATABASE_URL="postgresql://gob_user:gob_password@localhost:5432/gameofbraza"

# Auth.js — скопируй этот файл в apps/web/.env.local и заполни
# Сгенерировать секрет: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="сгенерируй-случайный-hex-32-байта"
AUTH_URL="http://localhost:3000"

# S3-совместимое хранилище (Cloudflare R2 или любой S3)
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"
